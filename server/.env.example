# =============================================================================
# SendDrive — Server Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# =============================================================================

# ── Azure App Registration credentials ────────────────────────────────────────
# Same app registration as before — also used below for staff sign-in
# verification (Authentication -> Single-page application platform ->
# redirect URI https://senddrive.bcim.in/ must be added in Azure Portal).
AZURE_CLIENT_ID=your_app_client_id_here
AZURE_CLIENT_SECRET=your_app_client_secret_here
AZURE_TENANT_ID=your_tenant_id_here

# Optional extra check on top of the tenant restriction above — reject sign-ins
# whose email isn't @this-domain even if they're in the tenant (e.g. guest
# accounts). Leave blank to rely on tenant restriction alone.
STAFF_EMAIL_DOMAIN=bcim.in

# ── OneDrive storage ──────────────────────────────────────────────────────────
ONEDRIVE_USER_UPN=uploads@yourcompany.com
UPLOAD_FOLDER=SendDrive

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# Full public URL (used in email links and share links)
BASE_URL=https://senddrive.bcim.in

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://senddrive.bcim.in

# ── Admin dashboard ───────────────────────────────────────────────────────────
ADMIN_PASSWORD=change_this_to_a_strong_password
