# =============================================================================
# SendDrive — Server Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# =============================================================================

# ── Azure App Registration credentials ────────────────────────────────────────
AZURE_CLIENT_ID=your_app_client_id_here
AZURE_CLIENT_SECRET=your_app_client_secret_here
AZURE_TENANT_ID=your_tenant_id_here

# ── OneDrive storage ──────────────────────────────────────────────────────────
ONEDRIVE_USER_UPN=uploads@yourcompany.com
UPLOAD_FOLDER=SendDrive

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# Full public URL (used in email links and share links)
BASE_URL=https://senddrive.bcim.in

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://senddrive.bcim.in

# ── Admin dashboard ───────────────────────────────────────────────────────────
ADMIN_PASSWORD=change_this_to_a_strong_password
