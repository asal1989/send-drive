# =============================================================================
# SendDrive — Frontend (Vite) Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# =============================================================================

# ── Azure App Registration — same app used by the server ──────────────────────
# Client ID / Tenant ID are NOT secrets (safe in a public frontend bundle) —
# only AZURE_CLIENT_SECRET on the server side is sensitive.
# Requires: Azure Portal -> App registrations -> this app -> Authentication ->
# Add a platform -> Single-page application -> redirect URI https://senddrive.bcim.in/
VITE_AZURE_CLIENT_ID=your_app_client_id_here
VITE_AZURE_TENANT_ID=your_tenant_id_here
